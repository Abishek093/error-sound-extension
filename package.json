{
  "name": "kattakada-error-sound-extension",
  "displayName": "Kattakada Error Sound",
  "description": "Plays a sound when a diagnostic error appears in your code",
  "version": "0.1.3",
  "publisher": "Abishek",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "error",
    "sound",
    "audio",
    "diagnostics",
    "accessibility"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Abishek093/error-sound-extension"
  },
  "bugs": {
    "url": "https://github.com/abishek093/error-sound-extension/issues"
  },
  "license": "MIT",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#2d2d2d",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Error Sound",
      "properties": {
        "errorSound.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the error sound"
        },
        "errorSound.playOnWarning": {
          "type": "boolean",
          "default": false,
          "description": "Also play sound for warnings (not just errors)"
        },
        "errorSound.debounceMs": {
          "type": "number",
          "default": 500,
          "description": "Minimum milliseconds between sound plays (avoid spam)"
        },
        "errorSound.soundFile": {
          "type": "string",
          "default": "",
          "description": "Sound filename in media/ folder (e.g. kattakada.mp3). Empty = auto-detect."
        },
        "errorSound.debug": {
          "type": "boolean",
          "default": false,
          "description": "Log sound playback to Developer Console (Help > Toggle Developer Tools)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "dev": "npm run compile && npm run watch",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "play-sound": "^1.1.6"
  }
}
